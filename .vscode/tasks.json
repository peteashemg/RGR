{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: clang сборка активного файла",
            "command": "/usr/bin/clang",
            "args": [
                "-fcolor-diagnostics",
                "-fansi-escape-codes",
                "-g",
                "${fileDirname}/main.cpp",
                "${fileDirname}/sencipher.cpp",
                "${fileDirname}/hillcipher.cpp",
                "${fileDirname}/keygenerator.cpp",
                "${fileDirname}/publickeycipher.cpp",
                "-o",
                "${fileDirname}/RGR"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Задача создана отладчиком."
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build active file",
            "command": "C:\\Program Files\\msys2\\ucrt64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${fileDirname}\\main.cpp",
                "${fileDirname}\\sencipher.cpp",
                "${fileDirname}\\hillcipher.cpp",
                "${fileDirname}\\keygenerator.cpp",
                "${fileDirname}\\publickeycipher.cpp",
                "-o",
                "${fileDirname}\\RGR.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}
